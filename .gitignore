# --- [ SECURITY & CREDENTIALS ] ---
# Never, ever push your Gemini API keys or MySQL passwords
.env
.env.local
.env.*.local
*.pem
*.key

# --- [ NODE.JS / BACKEND ] ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# --- [ ANTIGRAVITY / IDE SPECIFIC ] ---
# Ignoring IDE-specific metadata and local config
.antigravity/
.idx/
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.settings/

# --- [ DATABASE / DATA ] ---
# Ignore local data dumps (keep your schema.sql, but ignore the actual data)
*.sql.gz
*.sql.zip
database/local_backups/
database/temp_data/
dump.rdb

# --- [ FRONTEND / OS ] ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
dist/
build/